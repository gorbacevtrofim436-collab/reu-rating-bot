BOT_TOKEN=
BOT_ADMIN_USER_ID=
BOT_CREDENTIAL_KEY=
BOT_DB_PATH=credentials.sqlite3
RUN_MODE=polling

MONITOR_ENABLED=true
MONITOR_USER_DELAY_SECONDS=30
MONITOR_STOP_ON_TRANSIENT_FAILURE=false
SYNC_RETRY_USER_DELAY_SECONDS=10
PENDING_LOGIN_TTL_MINUTES=30
BOT_EVENT_RETENTION_DAYS=90
BROADCAST_USER_DELAY_SECONDS=0.1

INITIAL_SYNC_RETRY_DELAYS_SECONDS=0,15,35,55
INITIAL_SYNC_DEADLINE_SECONDS=70
INITIAL_SYNC_ATTEMPT_TIMEOUT_SECONDS=20

REA_RATING_URL=https://student.rea.ru/rating/index.php?login=yes&semester=2-й+семестр
REA_LOGIN_URL=https://student.rea.ru/
REA_LESSONS_URL=https://student.rea.ru/lessons/index.php?login=yes
REA_REQUEST_TIMEOUT=18
REA_SCHEDULE_REQUEST_TIMEOUT=18
REA_HTTP_RETRIES=1
REA_HTTP_CONNECT_RETRIES=1
REA_HTTP_READ_RETRIES=1
REA_HTTP_STATUS_RETRIES=1

BOT_BACKUP_DIR=/opt/reu-rating-bot/backups
BOT_BACKUP_RETENTION_DAYS=14
# Optional mounted external storage directory.
BOT_BACKUP_OFFSITE_DIR=
# Required together with BOT_BACKUP_OFFSITE_DIR. Generate another Fernet key.
BOT_BACKUP_KEY=
# Optional Healthchecks.io ping URL for an external watchdog signal.
HEALTHCHECKS_PING_URL=
